<!DOCTYPE html>
<html lang="<%= it.site.locale || 'en' %>">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= it.pageTitle %></title>
  <meta name="description" content="<%= it.pageDescription %>">
  <meta name="referrer" content="no-referrer-when-downgrade">
  <link rel="canonical" href="<%= it.canonicalUrl %>">
  <link rel="icon" href="/assets/logo.png" type="image/png">
  <link rel="alternate" type="application/rss+xml" title="<%= it.site.title %>" href="<%= it.baseUrl %>/rss.xml">

  <meta property="og:type" content="<%= it.ogType || 'website' %>">
  <meta property="og:site_name" content="<%= it.site.title %>">
  <meta property="og:title" content="<%= it.pageTitle %>">
  <meta property="og:description" content="<%= it.pageDescription %>">
  <meta property="og:url" content="<%= it.canonicalUrl %>">
  <% if (it.ogImage) { %><meta property="og:image" content="<%= it.ogImage %>"><% } %>
  <meta name="twitter:card" content="<%= it.ogImage ? 'summary_large_image' : 'summary' %>">
  <% if (it.site.twitter) { %><meta name="twitter:site" content="<%= it.site.twitter %>"><% } %>
  <% if (it.articleMeta) { %>
  <meta property="article:published_time" content="<%= it.articleMeta.published_at %>">
  <% if (it.articleMeta.updated_at) { %><meta property="article:modified_time" content="<%= it.articleMeta.updated_at %>"><% } %>
  <% if (it.articleMeta.primary_tag) { %><meta property="article:tag" content="<%= it.articleMeta.primary_tag.name %>"><% } %>
  <% } %>

  <link rel="stylesheet" href="/assets/app.css">
  <script defer src="/assets/main.js"></script>
  <% if (it.site.custom_css) { %><style><%~ it.site.custom_css %></style><% } %>
  <% if (it.site.code_injection_head) { %><%~ it.site.code_injection_head %><% } %>
</head>
<body class="<%= it.bodyClass || '' %>">
  <header class="site-head">
    <div class="site-head-inner">
      <a class="site-head-brand" href="/" aria-label="<%= it.site.title %> — home">
        <img class="site-head-logo" src="/assets/logo.png" alt="" width="40" height="40" decoding="async">
        <span class="site-head-wordmark">RoboDodd</span>
      </a>
      <nav class="site-head-nav" aria-label="Primary">
        <ul>
          <% (it.site.navigation || []).forEach(function(link){
             const ext = /^https?:/i.test(link.url) || /^mailto:/i.test(link.url);
             const icon = it.socialIcon(link.url);
          %>
            <li>
              <a href="<%= link.url %>"<%= ext ? ' target="_blank" rel="noopener noreferrer"' : '' %> class="<%= icon ? 'site-head-link is-icon' : 'site-head-link' %>" aria-label="<%= link.label %>">
                <% if (icon) { %><%~ icon %><span class="sr-only"><%= link.label %></span>
                <% } else { %><%= link.label %><% } %>
              </a>
            </li>
          <% }) %>
        </ul>
      </nav>
    </div>
    <div class="reading-progress" aria-hidden="true"><div class="reading-progress-bar"></div></div>
  </header>

  <%~ it.body %>

  <footer class="site-foot">
    <div class="site-foot-inner">
      <div class="site-foot-copy">© <%= new Date().getFullYear() %> <a href="/"><%= it.site.title %></a></div>
      <nav class="site-foot-nav" aria-label="Secondary">
        <ul>
          <% (it.site.secondary_navigation || []).forEach(function(link){ %>
            <li><a href="<%= link.url %>"<%= /^https?:/i.test(link.url) ? ' target="_blank" rel="noopener noreferrer"' : '' %>><%= link.label %></a></li>
          <% }) %>
        </ul>
      </nav>
    </div>
  </footer>
  <% if (it.site.code_injection_foot) { %><%~ it.site.code_injection_foot %><% } %>
</body>
</html>
